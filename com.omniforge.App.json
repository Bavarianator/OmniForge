{
  "app-id": "com.omniforge.App",
  "runtime": "org.gnome.Platform",
  "runtime-version": "46",
  "sdk": "org.gnome.Sdk",
  "command": "omniforge",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=home"
  ],
  "modules": [
    {
      "name": "omniforge",
      "buildsystem": "simple",
      "build-commands": ["cargo build --release -p omniforge-gui"],
      "sources": [{"type": "dir", "path": "."}]
    }
  ]
}
